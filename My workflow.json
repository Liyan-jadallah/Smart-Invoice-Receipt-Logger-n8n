    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const rawText =\n    item.json.text ||\n    item.json.output ||\n    item.json.response ||\n    item.json.message?.content ||\n    \"\";\n\n  const cleanedText = String(rawText)\n    .replace(/```json/g, \"\")\n    .replace(/```/g, \"\")\n    .trim();\n\n  let parsed;\n  try {\n    parsed = JSON.parse(cleanedText);\n  } catch (error) {\n    throw new Error(`Failed to parse LLM output as JSON. Raw output: ${cleanedText}`);\n  }\n\n  return {\n    json: parsed\n  };\n});"
      },
